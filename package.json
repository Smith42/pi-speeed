{
	"name": "pi-speeed",
	"version": "0.4.0",
	"description": "A pi extension that shows live model speed with a configurable RunCat speed badge.",
	"type": "module",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/somus/pi-speeed.git"
	},
	"homepage": "https://github.com/somus/pi-speeed#readme",
	"bugs": {
		"url": "https://github.com/somus/pi-speeed/issues"
	},
	"keywords": [
		"pi-package",
		"pi-extension",
		"pi",
		"runcat",
		"tokens",
		"tok/s"
	],
	"scripts": {
		"check": "biome check .",
		"check:fix": "biome check --write .",
		"typecheck": "tsc --noEmit",
		"test": "vitest run",
		"prepack": "npm run check && npm run typecheck && npm test"
	},
	"files": [
		"index.ts",
		"src/",
		"assets/",
		"README.md",
		"LICENSE",
		"tsconfig.json"
	],
	"pi": {
		"extensions": [
			"./index.ts"
		],
		"image": "https://raw.githubusercontent.com/somus/pi-speeed/main/assets/pi-speeed.gif"
	},
	"peerDependencies": {
		"@earendil-works/pi-ai": "*",
		"@earendil-works/pi-coding-agent": "*",
		"@earendil-works/pi-tui": "*"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.16",
		"@earendil-works/pi-ai": "^0.79.0",
		"@earendil-works/pi-coding-agent": "^0.79.0",
		"@earendil-works/pi-tui": "^0.79.0",
		"@types/node": "^24.13.1",
		"typescript": "^6.0.3",
		"vitest": "^4.1.8"
	},
	"publishConfig": {
		"access": "public"
	}
}
